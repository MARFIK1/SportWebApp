# dependencies
/node_modules
/.pnp
.pnp.js
.yarn/install-state.gz

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
logs/

# local env files
.env*.local

# vercel
.vercel
.vercel-deploy-staging/

# typescript
*.tsbuildinfo
next-env.d.ts

# user uploads
/public/uploads/

# user avatars
/public/avatars/

# IDE / editor config
.vscode/

# Prebuilt data (generated by scripts/prebuild.mjs)
/.data/

# SofascoreData - large data files (models, scraped data, reports)
SofascoreData/data/
SofascoreData/reports/
SofascoreData/top_picks/*.json
SofascoreData/**/__pycache__/
SofascoreData/*.db

# Python
__pycache__/
*.pyc
*.pyo
.venv/
venv/